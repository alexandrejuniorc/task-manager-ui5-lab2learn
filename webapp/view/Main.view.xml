                <List
                    id="taskList"
                    items="{/tasks}"
                >
                    <items>
                        <CustomListItem>
                            <HBox
                                justifyContent="SpaceBetween"
                                width="100%"
                                alignItems="Center"
                                class="sapUiSmallPadding"
                            >
                                <VBox>
                                    <Title
                                        text="{title}"
                                        level="H5"
                                    />
                                    <Text text="{description}" />

                                    <ObjectStatus
                                        text="{status}"
                                        state="{= ${status} === 'FEITO' ? 'Success' : ${status} === 'EM PROGRESSO' ? 'Warning' : 'Error'}"
                                    />
                                </VBox>

                                <ObjectStatus
                                    text="{priority}"
                                    state="{= ${priority} === 'ALTA' ? 'Error' : ${priority} === 'MEDIA' ? 'Warning' : 'Success'}"
                                />
                            </HBox>

                            <HBox alignItems="Center">
                                <Button
                                    icon="sap-icon://edit"
                                    type="Attention"
                                    tooltip="Editar Tarefa"
                                    press=".onEditTask"
                                    class="sapUiTinyMarginEnd"
                                />

                                <Button
                                    icon="sap-icon://delete"
                                    type="Reject"
                                    tooltip="Delete Tarefa"
                                    press=".onDeleteTask"
                                    class="sapUiTinyMarginEnd"
                                />
                            </HBox>
                        </CustomListItem>
                    </items>
                </List>
            </VBox>
        </content>
    </Page>

