<mvc:View
    xmlns:core="sap.ui.core"
    controllerName="studies.taskmanager.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <Page
        id="page"
        title="{i18n>title}"
    >
        <customHeader>
            <Toolbar>
                <Title text="{i18n>title}" />
            </Toolbar>
        </customHeader>

        <content>
            <VBox class="sapUiSmallMargin">
                <Toolbar>
                    <Title text="{i18n>newTask}" />
                </Toolbar>

                <HBox
                    class="sapUiSmallMarginBottom"
                    wrap="Wrap"
                >
                    <Input
                        id="titleInput"
                        placeholder="{i18n>titleInput}"
                        width="12.5rem"
                        class="sapUiTinyMarginEnd"
                    />

                    <Input
                        id="descInput"
                        placeholder="{i18n>descInput}"
                        width="16.25rem"
                        class="sapUiTinyMarginEnd"
                    />

                    <Select
                        id="prioritySelect"
                        width="8.75rem"
                        class="sapUiTinyMarginEnd"
                        selectedKey="{i18n>priorityLowKey}"
                    >
                        <items>
                            <core:Item
                                key="{i18n>priorityLowKey}"
                                text="{i18n>priorityLowKeyText}"
                            />
                            <core:Item
                                key="{i18n>priorityMediumKey}"
                                text="{i18n>priorityMediumKeyText}"
                            />
                            <core:Item
                                key="{i18n>priorityHighKey}"
                                text="{i18n>priorityHighKeyText}"
                            />
                        </items>
                    </Select>

                    <Button
                        text="{i18n>addTask}"
                        type="Emphasized"
                        press=".onAddTask"
                    />
                </HBox>

                <!-- <Toolbar>
